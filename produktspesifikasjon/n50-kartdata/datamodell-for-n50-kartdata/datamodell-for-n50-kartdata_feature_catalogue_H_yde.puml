@startuml
' For wide diagrams, render with: plantuml -DPLANTUML_LIMIT_SIZE=16384 ...
' The 'scale max' directive below caps the rendered output to prevent the
' default PlantUML 4096px size limit from cropping the diagram.
scale max 4000*4000

title N50 Kartdata - Datamodell for N50 kartdata - Høyde

skinparam backgroundColor #F5F5F5
skinparam shadowing false
skinparam RoundCorner 6
skinparam ArrowColor #6C8198
skinparam wrapWidth 200
skinparam class {
  BackgroundColor #FBF2E8
  BorderColor #9C8578
  FontColor #2D201A
  HeaderBackgroundColor #EFE1D6
  HeaderFontColor #2D201A
  AttributeIconSize 0
}
skinparam note {
  BackgroundColor #FFFFFF
  BorderColor #6C8198
  FontColor #2D201A
}
skinparam stereotypeCBackgroundColor #EAD9CE
skinparam stereotypeCBorderColor #9C8578
skinparam stereotypeCFontColor #2D201A

package "Høyde" {

  class "Høydekurve" as H_ydekurve <<featureType>> {
    + senterlinje [1] : GM_Curve
    + høyde [1] : Integer
  }

  class Terrengpunkt <<featureType>> {
    + posisjon [1] : GM_Point
    + høyde [1] : Integer
  }

  class TrigonometriskPunkt <<featureType>> {
    + posisjon [1] : GM_Point
    + høyde [1] : Integer
  }

  class Forsenkningskurve <<featureType>> {
    + senterlinje [1] : GM_Curve
    + høyde [1] : Integer
  }

  class Hjelpekurve <<featureType>> {
    + senterlinje [1] : GM_Curve
    + høyde [1] : Integer
  }
}

package "Eksterne referanser" <<Frame>> {
  class "SOSI_Objekt_PunkterOgLinjer_Høyde" as SOSI_Objekt_PunkterOgLinjer_H_yde <<Generelle typer>> {
  }
}

SOSI_Objekt_PunkterOgLinjer_H_yde <|-- H_ydekurve
SOSI_Objekt_PunkterOgLinjer_H_yde <|-- Terrengpunkt
SOSI_Objekt_PunkterOgLinjer_H_yde <|-- TrigonometriskPunkt
SOSI_Objekt_PunkterOgLinjer_H_yde <|-- Forsenkningskurve
SOSI_Objekt_PunkterOgLinjer_H_yde <|-- Hjelpekurve

@enduml
