  }

  class HavElvSperre <<featureType>> {
    + grense [1] : GM_Curve
  }

  class Golfbane <<featureType>> {
    + område [1] : GM_Surface
  }

  class "SnøIsbre" as Sn_Isbre <<featureType>> {
